# ============================================
# TRADOR — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# --- Binance Futures API ---
# Create API key at: https://www.binance.com/en/my/settings/api-management
# Enable Futures trading permission
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# --- Telegram Bot ---
# Create bot via @BotFather on Telegram
# Get token and chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- MiniMax LLM (for execution scoring only) ---
# Get API key from: https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M3
MINIMAX_ENABLED=true

# --- Hermes Communication ---
# Paths are relative to project root
SHARED_DIR=./shared
TRADOR_REPORTS_DIR=./shared/trador_reports
HERMES_SUGGESTIONS_DIR=./shared/hermes_suggestions

# --- Trading ---
# Default symbol to trade
DEFAULT_SYMBOL=ETHUSDT
# Testnet (set to true for testing)
TESTNET=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/trador.log
