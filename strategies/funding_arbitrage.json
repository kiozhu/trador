{
  "id": "funding_arbitrage",
  "name": "Funding Arbitrage",
  "version": 1,
  "description": "Funding rate arbitrage — go opposite direction when funding rate > threshold. Collect funding payments.",
  "indicators": {
    "funding_threshold_pct": 0.01,
    "ema_fast": 21,
    "ema_slow": 50
  },
  "entry": {
    "signal": "funding_rate_edge",
    "confirm": [
      "ema_alignment",
      "funding_rate_not_extreme"
    ],
    "funding_rate_threshold": 0.005,
    "min_hold_periods": 1,
    "max_funding_age_hours": 8,
    "min_mcap_usd": 50000
  },
  "position": {
    "size_type": "fixed_percent",
    "size_value": 10,
    "leverage": 3,
    "max_open": 3
  },
  "risk": {
    "sl_percent": 4.0,
    "tp_percent": 2.0,
    "trailing": false,
    "max_hold_minutes": 480,
    "breakeven_after_pct": 0.5,
    "funding_collect_target": 3
  },
  "filters": {
    "min_volume_24h_usd": 100000,
    "watch_funding_beat": true,
    "allow_overnight_hold": true
  },
  "direction": "both",
  "long_settings": {
    "sl_percent": 4.0,
    "tp_percent": 2.0,
    "entry_trigger": "high_negative_funding_short"
  },
  "short_settings": {
    "sl_percent": 4.0,
    "tp_percent": 2.0,
    "entry_trigger": "high_positive_funding_long"
  }
}